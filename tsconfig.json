{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "outDir": "./dist",
    "rootDir": ".",
    "baseUrl": ".",
    "paths": {
      "@objects": ["objects/index.ts"],
      "@objects/*": ["objects/*"],
      "@support/*": ["features/support/*"]
    }
  },
  "include": ["features/**/*.ts", "objects/**/*.ts"],
  "exclude": ["node_modules"]
}
